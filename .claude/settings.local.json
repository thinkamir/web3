{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "LS",
      "Edit",
      "MultiEdit",
      "Write",
      "Bash(pnpm *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git merge-base*)",
      "Bash(find *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/.env*)",
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(rm -rf *)"
    ]
  }
}
