{
  "name": "@alphaquest/contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node scripts/compile.js",
    "test": "node scripts/compile.js",
    "test:coverage": "node scripts/compile.js",
    "format": "forge fmt || true",
    "lint": "node scripts/compile.js",
    "deploy:local": "forge script script/Deploy.s.sol --fork http://localhost:8545",
    "deploy:sepolia": "forge script script/Deploy.s.sol --rpc-url $SEPOLIA_RPC_URL --broadcast"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "solc": "^0.8.30"
  },
  "devDependencies": {
    "forge-std": "^1.1.2"
  }
}
